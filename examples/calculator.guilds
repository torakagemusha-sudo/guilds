-- ---------------------------------------------------------------------------
-- SECTION 3: VESSELS
-- ---------------------------------------------------------------------------

vessel DisplayVessel {
    budget:      whole(0.15)
    phase:       any
    weight:      primary
    arrangement: sequence(primary, [1.0])
    contains:    [OperatorClaim, DisplayClaim, ResultClaim]
    failures: [
        FailureSpec {
            trigger:   overflow_error
            surfaces:  blocked
            propagates: no
        }
    ]
}

vessel PrimaryKeypad {
    budget:      whole(0.40)
    phase:       [idle, execute]
    weight:      primary
    arrangement: sequence(cross, [0.34, 0.33, 0.33])
    contains:    [DigitRowTop, DigitRowMiddle, DigitRowBottom]
}

vessel DigitRowTop {
    budget:      whole(0.13)
    phase:       [idle, execute]
    weight:      secondary
    arrangement: sequence(primary, [0.33, 0.34, 0.33])
    contains:    [Digit7Afford, Digit8Afford, Digit9Afford]
}

vessel DigitRowMiddle {
    budget:      whole(0.13)
    phase:       [idle, execute]
    weight:      secondary
    arrangement: sequence(primary, [0.33, 0.34, 0.33])
    contains:    [Digit4Afford, Digit5Afford, Digit6Afford]
}

vessel DigitRowBottom {
    budget:      whole(0.14)
    phase:       [idle, execute]
    weight:      secondary
    arrangement: sequence(primary, [0.33, 0.34, 0.33])
    contains:    [Digit1Afford, Digit2Afford, Digit3Afford]
}

vessel SecondaryKeypad {
    budget:      whole(0.10)
    phase:       [idle, execute]
    weight:      secondary
    arrangement: sequence(primary, [0.33, 0.34, 0.33])
    contains:    [NegateAfford, Digit0Afford, DecimalAfford]
}

vessel DigitPad {
    budget:      whole(0.50)
    phase:       [idle, execute]
    weight:      primary
    arrangement: sequence(cross, [0.80, 0.20])
    contains:    [PrimaryKeypad, SecondaryKeypad]
}

vessel OperatorPanel {
    budget:      whole(0.15)
    phase:       any
    weight:      secondary
    arrangement: sequence(primary, [0.20, 0.20, 0.20, 0.20, 0.20])
    contains:    [DivideAfford, MultiplyAfford, SubtractAfford, AddAfford, EqualsAfford]
}

vessel ControlPanel {
    budget:      whole(0.10)
    phase:       any
    weight:      secondary
    arrangement: sequence(primary, [0.50, 0.50])
    contains:    [ClearAfford, ClearEntryAfford]
}

vessel MemoryPanel {
    budget:      whole(0.10)
    phase:       any
    weight:      background
    arrangement: sequence(primary, [0.25, 0.25, 0.25, 0.25])
    contains:    [MemoryClaim, MemoryStoreAfford, MemoryRecallAfford, MemoryClearAfford]
}

vessel ErrorOverlay {
    budget:      whole(0.20)
    phase:       recover
    weight:      primary
    arrangement: sequence(primary, [1.0])
    contains:    [ErrorClaim, ClearAfford]
}

-- ---------------------------------------------------------------------------
-- SECTION 4: STAGE
-- ---------------------------------------------------------------------------

stage CalculatorStage {
    budget:  whole(1.0)

    phases: {
        idle: {
            arrangement: sequence(primary, [0.15, 0.10, 0.50, 0.15, 0.10])
            visible:     [DisplayVessel, ControlPanel, DigitPad, OperatorPanel]
            faded:       []
            hidden:      [ErrorOverlay, MemoryPanel]
            dominant:    DisplayVessel
        }
        execute: {
            arrangement: sequence(primary, [0.15, 0.10, 0.50, 0.15, 0.10])
            visible:     [DisplayVessel, ControlPanel, DigitPad, OperatorPanel]
            faded:       []
            hidden:      [ErrorOverlay, MemoryPanel]
            dominant:    DigitPad
        }
        verify: {
            arrangement: sequence(primary, [0.20, 0.10, 0.45, 0.15, 0.10])
            visible:     [DisplayVessel, ControlPanel, DigitPad, OperatorPanel]
            faded:       []
            hidden:      [ErrorOverlay, MemoryPanel]
            dominant:    DisplayVessel
        }
        recover: {
            arrangement: sequence(primary, [0.15, 0.20, 0.40, 0.15, 0.10])
            visible:     [DisplayVessel, ErrorOverlay]
            faded:       [DigitPad, OperatorPanel]
            hidden:      [ControlPanel, MemoryPanel]
            dominant:    ErrorOverlay
        }
    }

    default: {
        arrangement: sequence(primary, [0.15, 0.10, 0.50, 0.15, 0.10])
        visible:     [DisplayVessel, ControlPanel, DigitPad, OperatorPanel]
        faded:       []
        hidden:      [ErrorOverlay, MemoryPanel]
        dominant:    DisplayVessel
    }

    transition: {
        duration:   ms(100)
        curve:      ease-out
        sequence:   anchor_first
    }
}

-- ---------------------------------------------------------------------------
-- SECTION 5: FLOWS
-- ---------------------------------------------------------------------------

flow CalculationFlow {
    trigger:  user_action(EqualsAfford)
    steps: [
        step Computing {
            duration:   ms(100)
            state:      processing
            exit:       on_event(calculation_complete)
        }
        step DisplayingResult {
            duration:   ms(50)
            state:      completing
            exit:       on_complete
        }
    ]
    on_stall: {
        threshold:  s(1)
        surface:    blocked
        recovery:   [ClearAfford]
    }
    terminal: success | failure(blocked)
}

flow InputFlow {
    trigger:  user_action(Digit7Afford)
    steps: [
        step Appending {
            duration:   ms(16)
            state:      processing
            exit:       on_event(input_updated)
        }
    ]
    on_stall: {
        threshold:  ms(100)
        surface:    degraded
        recovery:   []
    }
    terminal: success | partial(degraded)
}

-- ---------------------------------------------------------------------------
-- SECTION 6: BONDS
-- ---------------------------------------------------------------------------

bond DisplayInputBond between (DisplayVessel, DigitPad) {
    kind:      corresponds(mapping = input_to_display)
    direction: unidirectional(from = DigitPad, to = DisplayVessel)
    strength:  rigid
    on_break:  blocked
}

bond DisplayOperatorBond between (DisplayVessel, OperatorPanel) {
    kind:      corresponds(mapping = operator_to_display)
    direction: unidirectional(from = OperatorPanel, to = DisplayVessel)
    strength:  rigid
    on_break:  blocked
}

bond MemoryDisplayBond between (MemoryPanel, DisplayVessel) {
    kind:      corresponds(mapping = memory_to_display)
    direction: bidirectional
    strength:  flexible
    on_break:  degraded
}
