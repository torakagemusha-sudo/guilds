-- =============================================================================
-- GUILDS Calculator Specification
-- =============================================================================
-- A simple calculator demonstrating basic GUILDS concepts:
-- - Claims for displaying values and results
-- - Affordances for digit and operator input
-- - Flows for calculation operations
-- - Phase transitions between entry and result states
-- =============================================================================

-- ---------------------------------------------------------------------------
-- SECTION 1: CLAIMS
-- ---------------------------------------------------------------------------

claim DisplayClaim {
    content:     text(display_value)
    certainty:   certain
    provenance:  source.direct(calculator_state)
    stakes:      medium
    freshness:   event_driven(input_change)
    on_stale:    mark_stale
}

claim ResultClaim {
    content:     numeric(calculation_result)
    certainty:   certain
    provenance:  source.derived(operands, method = arithmetic)
    stakes:      high
    freshness:   event_driven(calculation_complete)
    on_stale:    mark_stale
}

claim OperatorClaim {
    content:     status(current_operator)
    certainty:   certain
    provenance:  source.direct(calculator_state)
    stakes:      low
    freshness:   event_driven(operator_change)
    on_stale:    mark_stale
}

claim MemoryClaim {
    content:     numeric(memory_value)
    certainty:   certain
    provenance:  source.direct(memory_store)
    stakes:      medium
    freshness:   event_driven(memory_change)
    on_stale:    mark_stale
}

claim ErrorClaim {
    content:     text(error_message)
    certainty:   certain
    provenance:  source.direct(calculator_engine)
    stakes:      high
    freshness:   event_driven(error_occurred)
    on_stale:    remove
}

-- ---------------------------------------------------------------------------
-- SECTION 2: AFFORDANCES
-- ---------------------------------------------------------------------------

afford DigitAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     [input_allowed]
    contracts: [
        contract DigitInput {
            trigger:     user_action(DigitAfford)
            obligation:  execute(append_digit)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   fade_locked
}

afford OperatorAfford {
    perceivable:  always_visible
    offered:      select(cardinality = one)
    requires:     [has_operand]
    contracts: [
        contract SetOperator {
            trigger:     user_action(OperatorAfford)
            obligation:  execute(set_operator)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   fade_locked
}

afford EqualsAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     [has_operand, has_operator]
    contracts: [
        contract Calculate {
            trigger:     user_action(EqualsAfford)
            obligation:  execute(perform_calculation)
            deadline:    ms(100)
            on_breach:   blocked
        }
    ]
    on_unavail:   fade_locked
}

afford ClearAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     []
    contracts: [
        contract ClearAll {
            trigger:     user_action(ClearAfford)
            obligation:  execute(reset_calculator)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   hidden
}

afford ClearEntryAfford {
    perceivable:  context_revealed(has_input)
    offered:      activate
    requires:     [has_input]
    contracts: [
        contract ClearEntry {
            trigger:     user_action(ClearEntryAfford)
            obligation:  execute(clear_current_entry)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   hidden
}

afford MemoryStoreAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     [has_value]
    contracts: [
        contract StoreMemory {
            trigger:     user_action(MemoryStoreAfford)
            obligation:  execute(store_to_memory)
            deadline:    ms(50)
            on_breach:   degraded
        }
    ]
    on_unavail:   fade_locked
}

afford MemoryRecallAfford {
    perceivable:  context_revealed(memory_not_empty)
    offered:      activate
    requires:     [memory_not_empty]
    contracts: [
        contract RecallMemory {
            trigger:     user_action(MemoryRecallAfford)
            obligation:  execute(recall_from_memory)
            deadline:    ms(50)
            on_breach:   degraded
        }
    ]
    on_unavail:   hidden
}

afford MemoryClearAfford {
    perceivable:  context_revealed(memory_not_empty)
    offered:      activate
    requires:     [memory_not_empty]
    contracts: [
        contract ClearMemory {
            trigger:     user_action(MemoryClearAfford)
            obligation:  execute(clear_memory)
            deadline:    ms(50)
            on_breach:   degraded
        }
    ]
    on_unavail:   hidden
}

afford DecimalAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     [no_decimal_in_current]
    contracts: [
        contract AddDecimal {
            trigger:     user_action(DecimalAfford)
            obligation:  execute(append_decimal)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   fade_locked
}

afford NegateAfford {
    perceivable:  always_visible
    offered:      activate
    requires:     [has_value]
    contracts: [
        contract Negate {
            trigger:     user_action(NegateAfford)
            obligation:  execute(negate_value)
            deadline:    ms(16)
            on_breach:   degraded
        }
    ]
    on_unavail:   fade_locked
}

