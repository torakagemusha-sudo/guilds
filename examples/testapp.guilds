-- Testapp GUILDS Specification
-- Generated by guilds new

-- Certainty bindings
let knownCert = 0x03C40x2713
let inferredCert = 0x03C4~

-- Main content claim
claim MainContent {
    content:     text(content_data)
    certainty:   0x03C4~
    provenance:  source.direct(system)
    stakes:      medium
    freshness:   live
    on_stale:    mark_stale
}

-- Primary action
afford PrimaryAction {
    perceivable:  always_visible
    offered:      activate
    requires:     [action_ready]
    contracts: [
        contract ActionContract {
            trigger:     user_action(PrimaryAction)
            obligation:  execute(do_action)
            deadline:    ms(200)
            on_breach:   0x03A60x2193
        }
    ]
    on_unavail:   fade_locked
}

-- Main vessel
vessel MainVessel {
    budget:      whole(1.0)
    phase:       any
    weight:      primary
    arrangement: sequence(primary, [1.0])
    contains:    [MainContent, PrimaryAction]
}

-- Phase-coupled stage
stage TestappStage {
    budget:  whole(1.0)

    phases: {
        0x03C60x2205: {
            arrangement: sequence(primary, [1.0])
            visible:     [MainVessel]
            faded:       []
            hidden:      []
            dominant:    MainVessel
        }
        0x03C60x2081: {
            arrangement: sequence(primary, [1.0])
            visible:     [MainVessel]
            faded:       []
            hidden:      []
            dominant:    MainVessel
        }
    }

    default: {
        arrangement: sequence(primary, [1.0])
        visible:     [MainVessel]
        faded:       []
        hidden:      []
        dominant:    MainVessel
    }

    transition: {
        duration:   ms(150)
        curve:      ease-out
        sequence:   anchor_first
    }
}
